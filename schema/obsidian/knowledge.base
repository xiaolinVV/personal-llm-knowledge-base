filters:
  and:
    - file.ext == "md"
views:
  - type: table
    name: Intake Sources
    filters:
      and:
        - file.inFolder("raw/inbox") || file.inFolder("raw/sources") || status == "draft" || status == "indexed"
    order:
      - file.name
      - type
      - domain
      - status
      - updated
  - type: table
    name: Evergreen
    filters:
      and:
        - file.inFolder("wiki/topics") || type == "knowledge" || status == "evergreen"
    order:
      - file.name
      - domain
      - status
      - updated
  - type: table
    name: Research
    filters:
      and:
        - file.inFolder("wiki/research") || type == "research"
    order:
      - file.name
      - domain
      - status
      - updated
  - type: table
    name: Outputs
    filters:
      and:
        - file.inFolder("wiki/outputs") || type == "output"
    order:
      - file.name
      - domain
      - status
      - updated
  - type: table
    name: Recently Updated
    order:
      - file.name
      - type
      - domain
      - status
      - updated
    sort:
      - property: updated
        direction: DESC
